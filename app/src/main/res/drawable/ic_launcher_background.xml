<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base dark navy layer -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:fillColor="#001F3F" />

    <!-- Gradient overlay: diagonal blue wash top-left to bottom-right -->
    <!-- Simulated with multiple semi-transparent layers -->
    <path
        android:pathData="M0,0 L108,0 L0,108 Z"
        android:fillColor="#0288D1"
        android:fillAlpha="0.45" />

    <path
        android:pathData="M108,0 L108,108 L0,108 Z"
        android:fillColor="#0288D1"
        android:fillAlpha="0.30" />

    <!-- Center blend -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:fillColor="#0250A0"
        android:fillAlpha="0.20" />

</vector>
